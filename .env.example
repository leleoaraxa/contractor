# Application environment
ENVIRONMENT=local
LOG_LEVEL=INFO
CONTRACTOR_API_KEYS=dev-key
# CONTRACTOR_API_KEYS=key1,key2
CONTRACTOR_AUTH_DISABLED=0

# Runtime API (Data Plane)
RUNTIME_HOST=0.0.0.0
RUNTIME_PORT=8000
RUNTIME_BASE_URL=http://runtime:8000
RUNTIME_REDIS_URL=redis://redis:6379/0
# For running outside Docker Compose, use localhost instead:
# RUNTIME_REDIS_URL=redis://localhost:6379/0
POSTGRES_DSN=postgresql://postgres:contractor@contractor_db:5432/contractor
# Async /ask settings
# Enable async when question length exceeds threshold (default: 0=disabled)
RUNTIME_ASYNC_ENABLED=0
# Always force async responses (default: 0). Legacy alias: ASYNC_ALWAYS
RUNTIME_ASYNC_ALWAYS=0
# Minimum question length to trigger async (default: 200)
RUNTIME_ASYNC_QUESTION_LENGTH_THRESHOLD=200
# Result TTL for async responses (seconds, default: 600)
RUNTIME_ASYNC_RESULT_TTL_SECONDS=600
# Worker BLPOP block timeout (seconds, default: 5)
RUNTIME_ASYNC_WORKER_BLOCK_SECONDS=5

# Control Plane API
CONTROL_HOST=0.0.0.0
CONTROL_PORT=8001
CONTROL_BASE_URL=http://control:8001
# For running outside Docker Compose, use:
# CONTROL_BASE_URL=http://localhost:8001
CONTROL_AUDIT_LOG_PATH=registry/control_plane/audit.log

# Bundle registry (filesystem for Stage 0)
BUNDLE_REGISTRY_BASE=registry/tenants
CONTROL_ALIAS_STORE_PATH=registry/control_plane/tenant_aliases.json
CONTROL_QUALITY_REPORT_BASE=registry/control_plane/quality_reports

# Rate limiting (ADR 0013)
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
RATE_LIMIT_REDIS_URL=redis://redis:6379/0
# For running outside Docker Compose, use localhost instead:
# RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
